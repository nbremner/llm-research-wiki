# Copy to your local agent/runtime environment and fill in values there.
# Never commit real credentials.

# Path to the local Google Drive OAuth credentials file used by the backlog triage script.
# GOOGLE_OAUTH_FILE=/path/to/local/google-oauth-file

# Optional overrides for scripts/research-wiki-tools/pdf_backlog_triage.py
# RESEARCH_WIKI_INBOX_FOLDER_ID=your_drive_folder_id
# RESEARCH_WIKI_OUT_ROOT=/path/to/local/run/output
